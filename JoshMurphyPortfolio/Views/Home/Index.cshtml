<!-- Projects -->
<div class="bg-white py-5" id="projects">
    <div class="container py-4">
        <p class="text-primary text-uppercase fw-bold small mb-2">My Work</p>
        <h2 class="display-5 fw-bold mb-5">Projects</h2>
        <div class="row g-4 justify-content-center">

            <div class="col-lg-4 col-md-6">
                <div class="card h-100 border-10 shadow-sm">
                    <img src="~/images/project1.png" class="card-img-top" alt="Product Review Page"
                         style="cursor:pointer; height:180px; object-fit:cover;"
                         data-bs-toggle="modal" data-bs-target="#modal1">
                    <div class="card-body p-4">
                        <h5 class="fw-bold mb-2">Product Review Page</h5>
                        <p class="text-muted small mb-3">A product review web app where users can browse products, leave star ratings and comments, and view other reviews.</p>
                        <div class="mb-0">
                            <span class="badge bg-primary me-1">C#</span>
                            <span class="badge bg-secondary">ASP.NET Core</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-4 col-md-6">
                <div class="card h-100 border-10 shadow-sm">
                    <img src="~/images/project2-1.png" class="card-img-top" alt="Gold Clicker Game"
                        style="cursor:pointer; height:180px; object-fit:cover;"
                        data-bs-toggle="modal" data-bs-target="#modal2">
                    <div class="card-body p-4">
                        <h5 class="fw-bold mb-2">Gold Clicker Game</h5>
                        <p class="text-muted small mb-3">A clicker game where you mine gold and spend it on upgrades like Auto Miners and Gold Carts to increase your gold per second.</p>
                        <div class="mb-0">
                            <span class="badge bg-warning text-dark">Lua</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-4 col-md-6">
                <div class="card h-100 border-10 shadow-sm">
                    <img src="~/images/project3-1.png" class="card-img-top" alt="Your New Project"
                         style="cursor:pointer; height:180px; object-fit:cover;"
                         data-bs-toggle="modal" data-bs-target="#modal3">
                    <div class="card-body p-4">
                        <h5 class="fw-bold mb-2">Employee Claims System</h5>
                        <p class="text-muted small mb-3">A claims system with an employee & admin side. Employees can submit claims to be reviewed. Admins can review claims then approve or deny them.</p>
                        <div class="mb-0">
                            <span class="badge bg-primary me-1">C#</span>
                            <span class="badge bg-secondary">ASP.NET Core</span>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>

